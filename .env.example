# e-DON Lesson Studio — environment configuration example (project-context §4).
# Copy to .env for local dev, or to /etc/edon/edon.env on a VPS (systemd EnvironmentFile).
# Real secrets NEVER enter the repo; this file stays current as config grows (DoD §7).

EDON_ENV=dev
EDON_LOG_LEVEL=INFO

# Uvicorn bind (systemd unit and playwright webServer use 127.0.0.1:8100)
EDON_API_HOST=127.0.0.1
EDON_API_PORT=8100

# --- Future keys land with their stories; keep commented until then ---
# DATABASE_URL=postgresql://edon:CHANGE_ME@127.0.0.1:5432/edon   # Story 1.3 (tenant substrate)
# EDON_LLM_CONFIG=backend/src/edon/config/llm.yaml               # Story 1.5 (adapter workload config)
# EDON_RAG_BASE_URL=https://rag.example                          # Story 2.1 (retrieval client)
